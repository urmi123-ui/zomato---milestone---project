# LLM (Groq — Phase 4)
LLM_PROVIDER=groq
LLM_API_KEY=gsk_your_key_here
GROQ_API_KEY=gsk_your_key_here

LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
GROQ_BASE_URL=https://api.groq.com/openai/v1
MAX_ADDITIONAL_PREFERENCES_LENGTH=500

# Data
DATA_PATH=data/processed/restaurants.parquet
HF_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation

# Filtering (Phase 2+)
MAX_CANDIDATES=30

# Budget band thresholds (INR for two people)
BUDGET_LOW_MAX=500
BUDGET_MEDIUM_MAX=1500
