# LLM (Phase 3+)
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
OLLAMA_BASE_URL=http://localhost:11434
MAX_ADDITIONAL_PREFERENCES_LENGTH=500

# Data
DATA_PATH=data/processed/restaurants.parquet
HF_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation

# Filtering (Phase 2+)
MAX_CANDIDATES=30

# Budget band thresholds (INR for two people)
BUDGET_LOW_MAX=500
BUDGET_MEDIUM_MAX=1500
