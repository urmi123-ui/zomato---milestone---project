# Copy to .streamlit/secrets.toml for local Streamlit runs (do not commit real keys).
# On Streamlit Community Cloud, paste the same keys in App Settings → Secrets.

LLM_PROVIDER = "groq"
LLM_API_KEY = "gsk_your_key_here"
LLM_MODEL = "llama-3.3-70b-versatile"
GROQ_BASE_URL = "https://api.groq.com/openai/v1"
LLM_TEMPERATURE = "0.3"
LLM_TIMEOUT_SECONDS = "30"
LLM_MAX_RETRIES = "1"
MAX_CANDIDATES = "30"
DATA_PATH = "data/processed/restaurants.parquet"
HF_DATASET_ID = "ManikaSaini/zomato-restaurant-recommendation"
BUDGET_LOW_MAX = "500"
BUDGET_MEDIUM_MAX = "1500"
MAX_ADDITIONAL_PREFERENCES_LENGTH = "500"
